  ],
  "daily_auto": {
    "publish_hour_local": 10,
    "timezone": "Asia/Shanghai",
    "lookback_hours": 30,
    "max_candidate_items": 24,
    "min_posts_per_run": 1,
    "max_posts_per_run": 2,
    "min_sources_per_topic": 2,
    "cluster_similarity_threshold": 0.5,
    "enable_blogwatcher_fallback": true,
    "skip_published_topic_keys": true
  },
  "daily_manual": {
    "max_posts_per_run": 3,
    "lookback_hours": 36,
    "max_candidate_items": 30,
    "min_sources_per_topic": 1,
    "cluster_similarity_threshold": 0.45,
    "enable_blogwatcher_fallback": true,
    "skip_published_topic_keys": true
  },
  "weekly_review": {
    "format_profile": "weekly-review-v2",
    "lookback_days": 7,
    "base_feed_limit": 72,
    "base_enrich_limit": 30,
    "base_material_cap": 42,
    "blogwatcher_enabled": true,
    "blogwatcher_max_items": 18,
    "arxiv_enabled": true,
    "arxiv_optional": true,
    "arxiv_max_papers": 4,
    "arxiv_min_score": 0.8,
    "firecrawl_mode": "fallback",
    "exa_mode": "fallback",
    "target_min_chars": 9000,
    "section_target_chars": 1600
  },
  "series_assignment": {
    "enabled": true,
    "rules_path": "./series-assignment.rules.json",
    "default_series_slug": ""
  },
  "topic_presentation": {
    "enabled": true,
    "rules_path": "./topic-presentation.rules.json",
    "default_presentation": {
      "zh_title_template": "{topic}",
      "zh_subtitle_template": "{thesis}",
      "zh_description_template": "围绕 {topic} 的连续追踪，关注影响、取舍与落地进展。",
      "zh_tags": ["AI追踪", "主题线"]
    }
  },
  "source_diversity": {
    "enabled": true,
    "candidate_cap_per_source": 2,
    "enrichment_cap_per_source": 1,
