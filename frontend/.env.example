# Browser-visible API target for local development.
# Deployed Vercel builds should usually leave this unset so /api/* uses the same-origin Vercel rewrite.
VITE_API_BASE=http://127.0.0.1:8000
PUBLIC_SITE_URL=https://563118077.xyz

# Optional escape hatch for intentionally calling a cross-origin backend from the browser.
# Only enable this when the backend CORS policy explicitly allows your frontend origin.
# VITE_ALLOW_CROSS_ORIGIN_API=1

# Optional image proxy override
VITE_IMAGE_PROXY_BASE=http://127.0.0.1:8000/proxy-image
VITE_IMAGE_DIRECT_BASES=https://img.563118077.xyz,http://127.0.0.1:8000/uploads
