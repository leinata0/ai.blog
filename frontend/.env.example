# Browser-visible API target
VITE_API_BASE=http://127.0.0.1:8000

# Optional image proxy override
VITE_IMAGE_PROXY_BASE=http://127.0.0.1:8000/proxy-image
VITE_IMAGE_DIRECT_BASES=http://127.0.0.1:8000/uploads

# Vercel build/runtime rewrite target
# When omitted, the frontend talks to VITE_API_BASE directly.
# When set, vercel.mjs will proxy same-origin /api, /feed.xml, /uploads, and /proxy-image requests.
# VERCEL_BACKEND_ORIGIN=https://api.example.com
