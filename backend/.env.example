# Runtime mode
APP_ENV=development

# Development-only fallbacks
DEV_SECRET_KEY=dev-secret-key-change-me
DEV_ADMIN_USERNAME=admin
DEV_ADMIN_PASSWORD=admin123

# Production-required secrets
# SECRET_KEY=
# ADMIN_USERNAME=
# ADMIN_PASSWORD=

# Optional dedicated field-level encryption key for AI provider API keys.
# When omitted, a domain-separated key is derived from SECRET_KEY; plaintext
# storage is never allowed. Generate a separate key for stronger isolation with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# FIELD_ENCRYPTION_KEY=

# App URLs
PUBLIC_SITE_URL=http://127.0.0.1:5173
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Database
# DATABASE_URL=postgresql+psycopg://user:password@host/database?sslmode=require

# Seed behavior
AUTO_SEED_ON_EMPTY=1

# Client IP / rate limits behind reverse proxies (Cloudflare, Render LB).
# When unset, TRUST_PROXY_HEADERS auto-enables on Render. Set explicitly for
# other reverse-proxy deployments, or force off with TRUST_PROXY_HEADERS=0.
# TRUST_PROXY_HEADERS=1
# TRUSTED_PROXY_DEPTH=1
# Trust only when direct origin access is blocked and every request traverses
# Cloudflare, which overwrites CF-Connecting-IP.
# TRUST_CF_CONNECTING_IP=0

# Cloudflare R2 image storage
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=
# R2_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
# R2_PUBLIC_BASE_URL=https://images.your-domain.com
# R2_REGION=auto
# Production/Render fails closed when R2 is incomplete. Set to 1 only for an
# emergency deployment where uploaded files may disappear after a restart.
# ALLOW_EPHEMERAL_UPLOADS=0

# Notifications / subscriptions
# RESEND_API_KEY=
# EMAIL_FROM=AI 资讯观察 <noreply@example.com>
# WEB_PUSH_VAPID_PUBLIC_KEY=
# WEB_PUSH_VAPID_PRIVATE_KEY=
# WEB_PUSH_SUBJECT=mailto:owner@example.com
# WECOM_WEBHOOK_URLS=
# VERCEL_DEPLOY_HOOK_URL=

# Cover generation
# XAI_API_KEY=

# Cloudflare Turnstile (human verification on register/login).
# Leave unset to disable verification entirely (local/dev friendly).
# TURNSTILE_SECRET_KEY=
# Maximum time to wait for a paid image generation response before stopping
# without automatically resubmitting the request (60-600 seconds).
IMAGE_GENERATION_TIMEOUT_SECONDS=300
